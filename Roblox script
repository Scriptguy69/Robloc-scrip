-- Grow a Garden 2 DUPE - Compact
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Backpack = LocalPlayer:WaitForChild("Backpack")

-- Seed Detection
local SeedDetector = {}
SeedDetector.seeds = {}

function SeedDetector:Scan()
    local seeds = {}
    for _, item in pairs(Backpack:GetChildren()) do
        local name = item.Name:lower()
        if name:find("seed") or name:find("plant") or name:find("fruit") or name:find("flower") then
            if not table.find(seeds, item.Name) then
                table.insert(seeds, item.Name)
            end
        end
    end
    self.seeds = seeds
    return seeds
end

SeedDetector:Scan()

-- Dupe Engine
local DupeEngine = {}
DupeEngine.duping = false

function DupeEngine:Dupe(itemName, amount)
    if self.duping then return false end
    self.duping = true
    
    local item = Backpack:FindFirstChild(itemName)
    if not item then self.duping = false return false end
    
    for i = 1, amount do
        pcall(function()
            item:Clone().Parent = Backpack
        end)
        if i % 20 == 0 then wait(0.005) end
    end
    
    self.duping = false
    return true
end

